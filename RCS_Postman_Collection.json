		{
			"name": "Dashboard",
			"description": "Real-time dashboard API — returns agents, queue, stats, and call lists.",
			"item": [
				{
					"name": "Get Dashboard Data",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/dashboard/{{dashboard_key}}/api",
							"host": ["{{base_url}}"],
							"path": ["dashboard", "{{dashboard_key}}", "api"]
						},
						"description": "Returns the full dashboard payload: agents (with status, active call, calls answered), queue entries, aggregate stats (total calls, avg queue time, avg call duration, etc.), and call lists (recent, longest, longest queue wait, abandoned)."
					}
				}
			]
		},
		{
			"name": "Flows",
			"description": "End-to-end test sequences that simulate realistic call flows.",
			"item": [
				{
					"name": "Happy Path — Inbound Call",
					"description": "Simulate a full inbound call lifecycle: queue → ringing → answer → end.\nRun these requests in order.",
					"item": [
						{
							"name": "1. Agent Login",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n\t\"agent_id\": \"agent-rc-001\",\n\t\"event_type\": \"LOGIN\",\n\t\"event_aux_type\": \"LOGIN\",\n\t\"prev_state\": \"OFF-LINE\",\n\t\"prev_aux_state\": \"OFF-LINE\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/statuses",
									"host": ["{{base_url}}"],
									"path": ["statuses"]
								}
							}
						},
						{
							"name": "2. Agent Available",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n\t\"agent_id\": \"agent-rc-001\",\n\t\"event_type\": \"AVAILABLE\",\n\t\"event_aux_type\": \"AVAILABLE\",\n\t\"prev_state\": \"LOGIN\",\n\t\"prev_aux_state\": \"LOGIN\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/statuses",
									"host": ["{{base_url}}"],
									"path": ["statuses"]
								}
							}
